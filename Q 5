#include<iostream>
using namespace std;
int main(){
    int a,b;
    cout<<"Enter first number:";
    cin>>a;
    cout<<"Enter second number:";
    cin>>b;
    a=a*b;
    b=a/b;
    a=a/b;
    cout<<"First number after swapping is: "<<a<<endl;
    cout<<"Second number after swapping is: "<<b;
    return 0;
}
