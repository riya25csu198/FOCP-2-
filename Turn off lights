#include <iostream>
#include <vector>
#include <string>

using namespace std;

bool isFeasible(int n, int k, const string& bulbs, int l) {
    int operations = 0;
    for (int i = 0; i < n; ) {
        if (bulbs[i] == '1') {
            operations++;
            i += l; 
        } else {
            i++; 
        }
    }
    return operations <= k;
}

int main() {
    int n, k;
    if (!(cin >> n >> k)) 
	return 0;
    string bulbs;
    cin >> bulbs;

    int low = 1, high = n;
    int result = n;

    while (low <= high) {
        int mid = low + (high - low) / 2;
        if (isFeasible(n, k, bulbs, mid)) {
            result = mid;
            high = mid - 1; 
        } else {
            low = mid + 1; 
        }
    }

    cout << result << endl;

    return 0;
}




